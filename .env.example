# Antokton local/deployment environment example
# Copy to a local .env file only if your runner loads it.
# Do not commit real .env files, secrets, tokens, API keys, or passwords.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
NODE_NO_WARNINGS=1

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
# Main local backend/API/static server.
PORT=8787

# Temporary helper used only for live/import login tooling.
LIVE_IMPORT_PORT=8790

# Vite dev server normally uses its own CLI/default port.
# Keep this as documentation; Vite does not currently read it directly.
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# App identity
# -----------------------------------------------------------------------------
# Current Base44-exported app id, kept for compatibility with local API paths.
APP_ID=6991d40eddf82cc25ec834a7
VITE_ANTOKTON_APP_ID=6991d40eddf82cc25ec834a7

# Legacy compatibility variables still referenced by app-params.js.
# Prefer VITE_ANTOKTON_APP_ID for new work.
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=
VITE_BASE44_APP_BASE_URL=

# Exported Base44 function reference code may mention this.
# It is not required by the active local Node backend.
BASE44_APP_ID=

# -----------------------------------------------------------------------------
# Local development auth
# -----------------------------------------------------------------------------
# Development-only identity fallback. Do not use as the final production auth.
ANTOKTON_DEV_USER_EMAIL=admin@antokton.local
VITE_ANTOKTON_DEV_USER_EMAIL=admin@antokton.local
# Dev auth is automatically disabled when NODE_ENV=production.
ALLOW_DEV_AUTH=true

# Production beta auth.
# AUTH_BOOTSTRAP_ADMIN_* is optional and should be set only in the deployment
# secret manager to create/update the first admin login. Never commit real values.
AUTH_TOKEN_TTL_HOURS=336
AUTH_PASSWORD_MIN_LENGTH=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=8
AUTH_REGISTER_RATE_LIMIT_MAX=5
AUTH_PASSWORD_CHANGE_RATE_LIMIT_MAX=5
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# Production beta session cookie. Keep secure true in production; false only for local HTTP.
AUTH_SECRET=
JWT_SECRET=
SESSION_COOKIE_NAME=antokton_session
SESSION_COOKIE_SECURE=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Current local SQLite paths.
DATABASE_PROVIDER=sqlite
DATA_DIR=backend/data
DB_PATH=backend/data/antokton.sqlite

# Future PostgreSQL/Supabase-compatible database.
# Example shape only; do not commit real credentials.
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=antokton
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL=false
PGSSLMODE=require

# Supabase-compatible placeholders, if Supabase is chosen later.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Uploads and assets
# -----------------------------------------------------------------------------
# Current local uploads.
UPLOAD_DIR=backend/uploads
MAX_REMOTE_ASSET_BYTES=78643200

# Future object storage. Keep provider-neutral where possible.
# STORAGE_DRIVER can be local, s3, r2, or supabase.
STORAGE_DRIVER=local
STORAGE_PUBLIC_BASE_URL=
STORAGE_PRIVATE_BUCKET=
STORAGE_PUBLIC_BUCKET=

# S3/R2-compatible storage placeholders.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Supabase Storage placeholders.
SUPABASE_STORAGE_BUCKET=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Current backend only reads STRIPE_PUBLISHABLE_KEY and STRIPE_FALLBACK_URL.
STRIPE_PUBLISHABLE_KEY=
STRIPE_FALLBACK_URL=/Subscriptions

# Exported Base44 function reference code uses these; real production Stripe
# implementation should verify webhooks server-side.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Current backend logs Core.SendEmail locally. These are for future SMTP/provider
# implementation and should remain empty until configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@antokton.com

# Provider-neutral email placeholders.
EMAIL_PROVIDER=
EMAIL_API_KEY=

# -----------------------------------------------------------------------------
# AI/provider integrations
# -----------------------------------------------------------------------------
# Current Core.InvokeLLM is a placeholder. Configure later only after choosing
# a provider and documenting cost/security tradeoffs.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# -----------------------------------------------------------------------------
# Migration/import helpers only
# -----------------------------------------------------------------------------
# These are for importing live data during migration. Do not use in normal
# production runtime, and never commit real authorization/cookie values.
LIVE_ORIGIN=https://antokton.com
BASE44_API_URL=https://app.base44.com
LIVE_AUTHORIZATION=
LIVE_COOKIE=
LIVE_IMPORT_LIMIT=5000

# -----------------------------------------------------------------------------
# External publishing/reference integrations
# -----------------------------------------------------------------------------
# Exported Base44 reference functions mention Facebook publishing. Keep empty
# unless a production implementation is designed and approved.
FACEBOOK_PAGE_ACCESS_TOKEN=
